<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<section class="bento-section">

  <!-- ── HEADER ── -->
  <div class="bento-header">
    <h2 class="bento-title">{{ section.settings.title }}</h2>
    {% if section.settings.subtitle != blank %}
    <p class="bento-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
    {% if section.settings.badge_text != blank %}
    <div class="bento-badge">
      {% if section.settings.badge_icon != blank %}
        <img src="{{ section.settings.badge_icon | img_url: '32x32', crop: 'center' }}" width="18" height="18" style="border-radius:4px;" alt="">
      {% else %}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      {% endif %}
      <span>{{ section.settings.badge_text }}</span>
    </div>
    {% endif %}
  </div>

  <!-- ── GRILLE BENTO ── -->
  <div class="bento-grid">

    <!-- Carte 1 -->
    <div class="bento-card bento-card--1" style="background: {{ section.settings.card1_bg }}; border-color: {{ section.settings.card1_border }};">
      <div class="bento-card-text">
        <h3 class="bento-card-title" style="color: {{ section.settings.card1_title_color }}; font-size: {{ section.settings.card_title_size }}px;">{{ section.settings.card1_title }}</h3>
        {% if section.settings.card1_desc != blank %}
        <p class="bento-card-desc" style="color: {{ section.settings.card1_desc_color }}; font-size: {{ section.settings.card_desc_size }}px;">{{ section.settings.card1_desc }}</p>
        {% endif %}
      </div>
      {% if section.settings.card1_image != blank %}
      <div class="bento-card-img">
        <img src="{{ section.settings.card1_image | img_url: 'master' }}" alt="{{ section.settings.card1_title }}">
      </div>
      {% endif %}
    </div>

    <!-- Carte 2 -->
    <div class="bento-card bento-card--2" style="background: {{ section.settings.card2_bg }}; border-color: {{ section.settings.card2_border }};">
      <div class="bento-card-text">
        <h3 class="bento-card-title" style="color: {{ section.settings.card2_title_color }}; font-size: {{ section.settings.card_title_size }}px;">{{ section.settings.card2_title }}</h3>
        {% if section.settings.card2_desc != blank %}
        <p class="bento-card-desc" style="color: {{ section.settings.card2_desc_color }}; font-size: {{ section.settings.card_desc_size }}px;">{{ section.settings.card2_desc }}</p>
        {% endif %}
      </div>
      {% if section.settings.card2_image != blank %}
      <div class="bento-card-img">
        <img src="{{ section.settings.card2_image | img_url: 'master' }}" alt="{{ section.settings.card2_title }}">
      </div>
      {% endif %}
    </div>

    <!-- Carte 3 -->
    <div class="bento-card bento-card--3" style="background: {{ section.settings.card3_bg }}; border-color: {{ section.settings.card3_border }};">
      <div class="bento-card-text">
        <h3 class="bento-card-title" style="color: {{ section.settings.card3_title_color }}; font-size: {{ section.settings.card_title_size }}px;">{{ section.settings.card3_title }}</h3>
        {% if section.settings.card3_desc != blank %}
        <p class="bento-card-desc" style="color: {{ section.settings.card3_desc_color }}; font-size: {{ section.settings.card_desc_size }}px;">{{ section.settings.card3_desc }}</p>
        {% endif %}
      </div>
      {% if section.settings.card3_image != blank %}
      <div class="bento-card-img">
        <img src="{{ section.settings.card3_image | img_url: 'master' }}" alt="{{ section.settings.card3_title }}">
      </div>
      {% endif %}
    </div>

    <!-- Carte 4 -->
    <div class="bento-card bento-card--4" style="background: {{ section.settings.card4_bg }}; border-color: {{ section.settings.card4_border }};">
      <div class="bento-card-text">
        <h3 class="bento-card-title" style="color: {{ section.settings.card4_title_color }}; font-size: {{ section.settings.card_title_size }}px;">{{ section.settings.card4_title }}</h3>
        {% if section.settings.card4_desc != blank %}
        <p class="bento-card-desc" style="color: {{ section.settings.card4_desc_color }}; font-size: {{ section.settings.card_desc_size }}px;">{{ section.settings.card4_desc }}</p>
        {% endif %}
      </div>
      {% if section.settings.card4_image != blank %}
      <div class="bento-card-img">
        <img src="{{ section.settings.card4_image | img_url: 'master' }}" alt="{{ section.settings.card4_title }}">
      </div>
      {% endif %}
    </div>

  </div>
</section>

<style>
  .bento-section {
    background: {{ section.settings.bg_color }};
    {% if section.settings.use_gradient %}
    background: linear-gradient(160deg, {{ section.settings.gradient_color_1 }} 0%, {{ section.settings.gradient_color_2 }} 50%, {{ section.settings.gradient_color_3 }} 100%);
    {% endif %}
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_x }}px {{ section.settings.padding_bottom }}px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  /* ── HEADER ── */
  .bento-header {
    text-align: center;
    max-width: 780px;
    margin: 0 auto {{ section.settings.header_gap }}px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .bento-title {
    font-size: clamp({{ section.settings.title_size_mobile }}px, 5vw, {{ section.settings.title_size_desktop }}px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: {{ section.settings.title_color }};
    margin: 0;
  }
  .bento-subtitle {
    font-size: {{ section.settings.subtitle_size }}px;
    color: {{ section.settings.subtitle_color }};
    line-height: 1.65;
    margin: 0;
    max-width: 560px;
  }
  .bento-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    background: {{ section.settings.badge_bg }};
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    color: {{ section.settings.badge_color }};
  }

  /* ── GRILLE ── */
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: {{ section.settings.grid_gap }}px;
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── CARTES ── */
  .bento-card {
    border-radius: {{ section.settings.card_radius }}px;
    border: 1.5px solid;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: {{ section.settings.card_min_height }}px;
  }
  .bento-card-text {
    padding: 28px 28px 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .bento-card-title {
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin: 0;
  }
  .bento-card-desc {
    line-height: 1.6;
    margin: 0;
    max-width: 420px;
  }
  .bento-card-img {
    flex: 1;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .bento-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .bento-grid { grid-template-columns: 1fr; }
    .bento-card { min-height: 280px; }
    .bento-card-text { padding: 20px 20px 16px; }
    .bento-title { letter-spacing: -0.02em; }
  }
</style>

{% schema %}
{
  "name": "Bento Fonctionnalités",
  "tag": "section",
  "class": "section-bento",
  "settings": [

    { "type": "header", "content": "🎨 Fond & Espacement" },
    { "type": "color", "id": "bg_color", "label": "Couleur de fond", "default": "#faf5ff" },
    { "type": "checkbox", "id": "use_gradient", "label": "Utiliser un dégradé", "default": true },
    { "type": "color", "id": "gradient_color_1", "label": "Dégradé couleur 1", "default": "#fce7f3" },
    { "type": "color", "id": "gradient_color_2", "label": "Dégradé couleur 2", "default": "#ede9fe" },
    { "type": "color", "id": "gradient_color_3", "label": "Dégradé couleur 3", "default": "#dbeafe" },
    { "type": "range", "id": "padding_top", "label": "Padding haut (px)", "min": 0, "max": 150, "step": 5, "default": 60 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bas (px)", "min": 0, "max": 150, "step": 5, "default": 60 },
    { "type": "range", "id": "padding_x", "label": "Padding latéral (px)", "min": 0, "max": 80, "step": 4, "default": 24 },
    { "type": "range", "id": "grid_gap", "label": "Espacement entre cartes (px)", "min": 4, "max": 40, "step": 2, "default": 16 },

    { "type": "header", "content": "✏️ Titre & Sous-titre" },
    { "type": "textarea", "id": "title", "label": "Titre principal", "default": "Pourquoi nos boutiques vendent là où les autres échouent..." },
    { "type": "color", "id": "title_color", "label": "Couleur du titre", "default": "#0a0a0a" },
    { "type": "range", "id": "title_size_desktop", "label": "Taille titre Desktop (px)", "min": 28, "max": 90, "step": 2, "default": 56 },
    { "type": "range", "id": "title_size_mobile", "label": "Taille titre Mobile (px)", "min": 20, "max": 50, "step": 2, "default": 30 },
    { "type": "text", "id": "subtitle", "label": "Sous-titre", "default": "Une architecture pensée pour vendre, pas juste pour \"faire joli\"" },
    { "type": "color", "id": "subtitle_color", "label": "Couleur sous-titre", "default": "#6b7280" },
    { "type": "range", "id": "subtitle_size", "label": "Taille sous-titre (px)", "min": 12, "max": 20, "step": 1, "default": 15 },
    { "type": "range", "id": "header_gap", "label": "Espace titre / grille (px)", "min": 16, "max": 80, "step": 4, "default": 40 },

    { "type": "header", "content": "🏷️ Badge" },
    { "type": "text", "id": "badge_text", "label": "Texte du badge", "default": "€380 (Thème premium habituellement vendu 380€)" },
    { "type": "color", "id": "badge_bg", "label": "Fond du badge", "default": "#f0fdf4" },
    { "type": "color", "id": "badge_color", "label": "Couleur texte badge", "default": "#16a34a" },
    { "type": "image_picker", "id": "badge_icon", "label": "Icône badge (optionnel)" },

    { "type": "header", "content": "📐 Style des cartes" },
    { "type": "range", "id": "card_radius", "label": "Arrondi des cartes (px)", "min": 0, "max": 40, "step": 2, "default": 20 },
    { "type": "range", "id": "card_min_height", "label": "Hauteur min cartes (px)", "min": 200, "max": 700, "step": 10, "default": 400 },
    { "type": "range", "id": "card_title_size", "label": "Taille titre carte (px)", "min": 14, "max": 32, "step": 1, "default": 20 },
    { "type": "range", "id": "card_desc_size", "label": "Taille description carte (px)", "min": 11, "max": 18, "step": 1, "default": 14 },

    { "type": "header", "content": "🃏 Carte 1 (haut gauche)" },
    { "type": "text", "id": "card1_title", "label": "Titre", "default": "Un thème premium conçu par des développeurs experts" },
    { "type": "textarea", "id": "card1_desc", "label": "Description", "default": "Plus de 50 sections sur-mesure, pensées pour la conversion, le branding et l'expérience utilisateur." },
    { "type": "image_picker", "id": "card1_image", "label": "Image" },
    { "type": "color", "id": "card1_bg", "label": "Fond", "default": "#ffffff" },
    { "type": "color", "id": "card1_border", "label": "Bordure", "default": "#e5e7eb" },
    { "type": "color", "id": "card1_title_color", "label": "Couleur titre", "default": "#0a0a0a" },
    { "type": "color", "id": "card1_desc_color", "label": "Couleur description", "default": "#6b7280" },

    { "type": "header", "content": "🃏 Carte 2 (haut droite)" },
    { "type": "text", "id": "card2_title", "label": "Titre", "default": "Panier optimisé pour la conversion" },
    { "type": "textarea", "id": "card2_desc", "label": "Description", "default": "Barre de progression, bénéfices, impulsions d'achat, garanties + upsells sans quitter le panier." },
    { "type": "image_picker", "id": "card2_image", "label": "Image" },
    { "type": "color", "id": "card2_bg", "label": "Fond", "default": "#ffffff" },
    { "type": "color", "id": "card2_border", "label": "Bordure", "default": "#e5e7eb" },
    { "type": "color", "id": "card2_title_color", "label": "Couleur titre", "default": "#0a0a0a" },
    { "type": "color", "id": "card2_desc_color", "label": "Couleur description", "default": "#6b7280" },

    { "type": "header", "content": "🃏 Carte 3 (bas gauche)" },
    { "type": "text", "id": "card3_title", "label": "Titre", "default": "Mobile-first & ultra rapide" },
    { "type": "textarea", "id": "card3_desc", "label": "Description", "default": "Performant là où se font les ventes" },
    { "type": "image_picker", "id": "card3_image", "label": "Image" },
    { "type": "color", "id": "card3_bg", "label": "Fond", "default": "#ffffff" },
    { "type": "color", "id": "card3_border", "label": "Bordure", "default": "#e5e7eb" },
    { "type": "color", "id": "card3_title_color", "label": "Couleur titre", "default": "#0a0a0a" },
    { "type": "color", "id": "card3_desc_color", "label": "Couleur description", "default": "#6b7280" },

    { "type": "header", "content": "🃏 Carte 4 (bas droite)" },
    { "type": "text", "id": "card4_title", "label": "Titre", "default": "Pages Produits Ultra Complètes" },
    { "type": "textarea", "id": "card4_desc", "label": "Description", "default": "UGC, storytelling, FAQ intégrée, comparatif, avant/après…" },
    { "type": "image_picker", "id": "card4_image", "label": "Image" },
    { "type": "color", "id": "card4_bg", "label": "Fond", "default": "#ffffff" },
    { "type": "color", "id": "card4_border", "label": "Bordure", "default": "#e5e7eb" },
    { "type": "color", "id": "card4_title_color", "label": "Couleur titre", "default": "#0a0a0a" },
    { "type": "color", "id": "card4_desc_color", "label": "Couleur description", "default": "#6b7280" }

  ],
  "presets": [{ "name": "Bento Fonctionnalités" }]
}
{% endschema %}