<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<section class="hdf-section">
  <div class="hdf-noise"></div>
  <div class="hdf-glow hdf-glow--left"></div>
  <div class="hdf-glow hdf-glow--right"></div>

  <div class="hdf-inner">

    {% if section.settings.badge_text != blank %}
    <div class="hdf-badge">
      <span class="hdf-dot" style="background:{{ section.settings.accent_color }};box-shadow:0 0 6px {{ section.settings.accent_color }};"></span>
      {{ section.settings.badge_text }}
    </div>
    {% endif %}

    <h1 class="hdf-title">
      {{ section.settings.title_start }}
      {% if section.settings.title_dim_1 != blank %}<span class="hdf-dim">{{ section.settings.title_dim_1 }}</span>{% endif %}
      <span style="color:{{ section.settings.title_bold_color }};">{{ section.settings.title_bold_1 }}</span>
      {{ section.settings.title_mid }}
      <br>
      <span class="hdf-dim">{{ section.settings.title_dim_2 }}</span>
      <span style="color:{{ section.settings.title_bold_color }};">{{ section.settings.title_bold_2 }}</span>
    </h1>

    {% if section.settings.desc_bold != blank or section.settings.desc_text != blank %}
    <p class="hdf-desc">
      {% if section.settings.desc_bold != blank %}<strong>{{ section.settings.desc_bold }}</strong>{% endif %}
      {{ section.settings.desc_text }}
    </p>
    {% endif %}

    {% if section.settings.cta_text != blank %}
    <a href="{{ section.settings.cta_url }}" class="hdf-cta">
      {% if section.settings.show_cta_dot %}<span class="hdf-dot" style="background:{{ section.settings.accent_color }};box-shadow:0 0 6px {{ section.settings.accent_color }};"></span>{% endif %}
      {{ section.settings.cta_text }}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    {% endif %}

    {% if section.settings.show_social %}
    <div class="hdf-social">
      <div class="hdf-avatars">
        {% if section.settings.avatar_1 != blank %}
          <img src="{{ section.settings.avatar_1 | img_url: '68x68', crop: 'center' }}" class="hdf-avatar" alt="membre">
        {% else %}
          <div class="hdf-avatar hdf-avatar--fallback" style="background:linear-gradient(135deg,#f97316,#ec4899);"></div>
        {% endif %}
        {% if section.settings.avatar_2 != blank %}
          <img src="{{ section.settings.avatar_2 | img_url: '68x68', crop: 'center' }}" class="hdf-avatar" alt="membre">
        {% else %}
          <div class="hdf-avatar hdf-avatar--fallback" style="background:linear-gradient(135deg,#3b82f6,#8b5cf6);"></div>
        {% endif %}
        {% if section.settings.avatar_3 != blank %}
          <img src="{{ section.settings.avatar_3 | img_url: '68x68', crop: 'center' }}" class="hdf-avatar" alt="membre">
        {% else %}
          <div class="hdf-avatar hdf-avatar--fallback" style="background:linear-gradient(135deg,#10b981,#06b6d4);"></div>
        {% endif %}
        {% if section.settings.avatar_4 != blank %}
          <img src="{{ section.settings.avatar_4 | img_url: '68x68', crop: 'center' }}" class="hdf-avatar" alt="membre">
        {% else %}
          <div class="hdf-avatar hdf-avatar--fallback" style="background:linear-gradient(135deg,#f59e0b,#ef4444);"></div>
        {% endif %}
      </div>
      <div class="hdf-social-info">
        <div class="hdf-stars">
          {% for i in (1..5) %}<span style="color:{{ section.settings.star_color }};">★</span>{% endfor %}
        </div>
        {% if section.settings.social_count != blank %}
          <span class="hdf-social-count">{{ section.settings.social_count }}</span>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {% if section.settings.show_stats %}
    <div class="hdf-stats">
      {% for i in (1..4) %}
        {% assign stat_label_key = 'stat_' | append: i | append: '_label' %}
        {% assign stat_value_key = 'stat_' | append: i | append: '_value' %}
        {% assign stat_label = section.settings[stat_label_key] %}
        {% assign stat_value = section.settings[stat_value_key] %}
        {% if stat_value != blank %}
        <div class="hdf-stat">
          <span class="hdf-stat-label">{{ stat_label }}</span>
          <span class="hdf-stat-value" style="color:{{ section.settings.stat_value_color }};">{{ stat_value }}</span>
        </div>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

  </div>
</section>

<style>
  .hdf-section {
    position: relative;
    background: {{ section.settings.bg_color }};
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .hdf-noise {
    position: absolute; inset: 0; opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px; pointer-events: none; z-index: 0;
  }
  .hdf-glow { position: absolute; width: 700px; height: 700px; border-radius: 50%; filter: blur(140px); opacity: 0.15; pointer-events: none; z-index: 0; }
  .hdf-glow--left  { background: radial-gradient(circle, #1a4a2e, transparent 70%); left: -250px; top: -100px; }
  .hdf-glow--right { background: radial-gradient(circle, #1a3a4a, transparent 70%); right: -250px; bottom: -50px; }
  .hdf-inner {
    position: relative; z-index: 1; text-align: center;
    max-width: 820px; width: 100%;
    display: flex; flex-direction: column; align-items: center; gap: 20px;
    animation: hdfUp 0.8s ease both;
  }
  @keyframes hdfUp { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }
  .hdf-badge {
    display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px;
    background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.15);
    border-radius: 999px; font-size: 12px; font-weight: 500; color: rgba(255,255,255,0.75);
    backdrop-filter: blur(8px);
  }
  .hdf-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; animation: hdfPulse 2s infinite; }
  @keyframes hdfPulse { 0%,100%{opacity:1} 50%{opacity:0.35} }
  .hdf-title { font-size: clamp(28px, 5vw, {{ section.settings.title_size }}px); font-weight: 800; line-height: 1.1; letter-spacing: -0.03em; color: #fff; margin: 0; }
  .hdf-dim { color: rgba(255,255,255,0.38); }
  .hdf-desc { font-size: 14px; color: rgba(255,255,255,0.5); max-width: 520px; line-height: 1.75; letter-spacing: -0.01em; margin: 0; }
  .hdf-desc strong { color: rgba(255,255,255,0.85); font-weight: 600; }
  .hdf-cta {
    display: inline-flex; align-items: center; gap: 8px; padding: 12px 28px;
    background: #fff; color: #0d0d0d; border-radius: 999px; font-size: 14px; font-weight: 600;
    text-decoration: none; letter-spacing: -0.01em; transition: transform .2s, box-shadow .2s;
  }
  .hdf-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(255,255,255,0.1); }
  .hdf-social { display: flex; align-items: center; gap: 12px; }
  .hdf-avatars { display: flex; }
  .hdf-avatar { width: 36px; height: 36px; border-radius: 50%; border: 2px solid {{ section.settings.bg_color }}; margin-left: -10px; object-fit: cover; }
  .hdf-avatar--fallback { display: inline-block; }
  .hdf-avatars .hdf-avatar:first-child { margin-left: 0; }
  .hdf-social-info { display: flex; flex-direction: column; align-items: flex-start; gap: 1px; }
  .hdf-stars { display: flex; gap: 1px; font-size: 16px; line-height: 1; }
  .hdf-social-count { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.6); letter-spacing: -0.01em; }
  .hdf-stats {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1px; width: 100%; max-width: 760px;
    background: rgba(255,255,255,0.06); border-radius: 12px; overflow: hidden;
  }
  .hdf-stat { display: flex; flex-direction: column; align-items: center; gap: 4px; padding: 20px 16px; background: {{ section.settings.bg_color }}; }
  .hdf-stat-label { font-size: 11.5px; color: rgba(255,255,255,0.45); text-align: center; line-height: 1.4; letter-spacing: -0.01em; }
  .hdf-stat-value { font-size: clamp(22px, 3vw, 28px); font-weight: 800; letter-spacing: -0.03em; line-height: 1; }
  @media (max-width: 768px) {
    .hdf-title { font-size: 28px; }
    .hdf-stats { grid-template-columns: repeat(2, 1fr); }
    .hdf-stat { padding: 16px 12px; }
  }
  @media (max-width: 480px) {
    .hdf-title { font-size: 24px; }
    .hdf-cta { font-size: 13px; padding: 11px 22px; }
  }
</style>

{% schema %}
{
  "name": "Hero Dark Complet",
  "tag": "section",
  "class": "section-hero-dark-full",
  "settings": [
    { "type": "header", "content": "🎨 Couleurs globales" },
    { "type": "color", "id": "bg_color", "label": "Fond", "default": "#0d0d0d" },
    { "type": "color", "id": "accent_color", "label": "Couleur accent", "default": "#00B67A" },
    { "type": "header", "content": "📐 Espacement" },
    { "type": "range", "id": "padding_top", "label": "Padding haut (px)", "min": 0, "max": 150, "step": 5, "default": 70 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bas (px)", "min": 0, "max": 150, "step": 5, "default": 70 },
    { "type": "header", "content": "🏷️ Badge" },
    { "type": "text", "id": "badge_text", "label": "Texte du badge", "default": "8lab Ecosystem · The Infinite" },
    { "type": "header", "content": "✏️ Titre" },
    { "type": "range", "id": "title_size", "label": "Taille max titre (px)", "min": 30, "max": 100, "step": 2, "default": 62 },
    { "type": "text", "id": "title_start", "label": "Texte blanc - début", "default": "Le seul écosystème" },
    { "type": "text", "id": "title_dim_1", "label": "Texte gris 1", "default": "pour" },
    { "type": "text", "id": "title_bold_1", "label": "Texte coloré 1", "default": "créer" },
    { "type": "text", "id": "title_mid", "label": "Texte blanc - milieu", "default": "et" },
    { "type": "text", "id": "title_dim_2", "label": "Texte gris 2", "default": "scaler" },
    { "type": "text", "id": "title_bold_2", "label": "Texte coloré 2", "default": "son" },
    { "type": "color", "id": "title_bold_color", "label": "Couleur des mots colorés", "default": "#ffffff" },
    { "type": "header", "content": "📝 Description" },
    { "type": "text", "id": "desc_bold", "label": "Texte en gras", "default": "Le 8lab vous offre un plan étape par étape," },
    { "type": "textarea", "id": "desc_text", "label": "Suite du texte", "default": " le réseau et les outils pour créer une marque e-commerce pérenne." },
    { "type": "header", "content": "🔘 Bouton CTA" },
    { "type": "text", "id": "cta_text", "label": "Texte du bouton", "default": "Rejoindre au prochain LIVE" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton" },
    { "type": "checkbox", "id": "show_cta_dot", "label": "Afficher le point animé", "default": true },
    { "type": "header", "content": "👥 Preuve sociale" },
    { "type": "checkbox", "id": "show_social", "label": "Afficher la preuve sociale", "default": true },
    { "type": "image_picker", "id": "avatar_1", "label": "Photo membre 1" },
    { "type": "image_picker", "id": "avatar_2", "label": "Photo membre 2" },
    { "type": "image_picker", "id": "avatar_3", "label": "Photo membre 3" },
    { "type": "image_picker", "id": "avatar_4", "label": "Photo membre 4" },
    { "type": "color", "id": "star_color", "label": "Couleur des étoiles", "default": "#00B67A" },
    { "type": "text", "id": "social_count", "label": "Texte du compteur", "default": "+2086 membres" },
    { "type": "header", "content": "📊 Statistiques" },
    { "type": "checkbox", "id": "show_stats", "label": "Afficher les statistiques", "default": true },
    { "type": "color", "id": "stat_value_color", "label": "Couleur des chiffres", "default": "#ffffff" },
    { "type": "text", "id": "stat_1_label", "label": "Stat 1 - Label", "default": "Nombre de membres actifs" },
    { "type": "text", "id": "stat_1_value", "label": "Stat 1 - Valeur", "default": "1365" },
    { "type": "text", "id": "stat_2_label", "label": "Stat 2 - Label", "default": "CA générés par les membres" },
    { "type": "text", "id": "stat_2_value", "label": "Stat 2 - Valeur", "default": "$45M+" },
    { "type": "text", "id": "stat_3_label", "label": "Stat 3 - Label", "default": "Satisfaction de nos membres" },
    { "type": "text", "id": "stat_3_value", "label": "Stat 3 - Valeur", "default": "99,8%" },
    { "type": "text", "id": "stat_4_label", "label": "Stat 4 - Label", "default": "Nombre d'heures de contenu" },
    { "type": "text", "id": "stat_4_value", "label": "Stat 4 - Valeur", "default": "150" }
  ],
  "presets": [{ "name": "Hero Dark Complet" }]
}
{% endschema %}