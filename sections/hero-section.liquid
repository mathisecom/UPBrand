<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<section class="hero-dark-section" style="padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;">
  <div class="hero-noise"></div>
  <div class="hero-glow hero-glow--left"></div>
  <div class="hero-glow hero-glow--right"></div>

  <div class="hero-inner">

    {% if section.settings.badge_text != blank %}
    <div class="hero-badge">
      <span class="hero-badge__dot" style="background: {{ section.settings.accent_color }}; box-shadow: 0 0 6px {{ section.settings.accent_color }};"></span>
      {{ section.settings.badge_text }}
    </div>
    {% endif %}

    <h1 class="hero-title">
      {{ section.settings.title_start }}
      {% if section.settings.title_highlight_1 != blank %}
        <span class="hero-dim">{{ section.settings.title_highlight_1 }}</span>
      {% endif %}
      {{ section.settings.title_middle }}
      {% if section.settings.title_break %}<br>{% endif %}
      {% if section.settings.title_highlight_2 != blank %}
        <span class="hero-dim">{{ section.settings.title_highlight_2 }}</span>
      {% endif %}
      {{ section.settings.title_end }}
    </h1>

    {% if section.settings.description != blank %}
    <p class="hero-desc">
      {% if section.settings.description_bold != blank %}
        <strong>{{ section.settings.description_bold }}</strong>
      {% endif %}
      {{ section.settings.description }}
    </p>
    {% endif %}

    {% if section.settings.cta_text != blank %}
    <a href="{{ section.settings.cta_url }}" class="hero-cta">
      {% if section.settings.show_cta_dot %}
        <span class="hero-cta__dot" style="background: {{ section.settings.accent_color }}; box-shadow: 0 0 6px {{ section.settings.accent_color }};"></span>
      {% endif %}
      {{ section.settings.cta_text }}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    {% endif %}

    {% if section.settings.show_social_proof %}
    <div class="hero-social">
      <div class="hero-avatars">
        <div class="hero-avatar" style="background: linear-gradient(135deg,#f97316,#ec4899);"></div>
        <div class="hero-avatar" style="background: linear-gradient(135deg,#3b82f6,#8b5cf6);"></div>
        <div class="hero-avatar" style="background: linear-gradient(135deg,#10b981,#06b6d4);"></div>
        <div class="hero-avatar" style="background: linear-gradient(135deg,#f59e0b,#ef4444);"></div>
      </div>
      <div class="hero-social__info">
        <div class="hero-stars">
          {% for i in (1..5) %}
            <span style="color: {{ section.settings.star_color }}; font-size: 16px;">★</span>
          {% endfor %}
        </div>
        {% if section.settings.social_count != blank %}
          <span class="hero-social__count">{{ section.settings.social_count }}</span>
        {% endif %}
      </div>
    </div>
    {% endif %}

  </div>
</section>

<style>
  .hero-dark-section {
    position: relative;
    background: {{ section.settings.bg_color }};
    min-height: {{ section.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }
  .hero-noise {
    position: absolute;
    inset: 0;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 180px;
    pointer-events: none;
    z-index: 0;
  }
  .hero-glow {
    position: absolute;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.18;
    pointer-events: none;
    z-index: 0;
  }
  .hero-glow--left {
    background: radial-gradient(circle, #1a4a2e, transparent 70%);
    left: -200px;
    top: -100px;
  }
  .hero-glow--right {
    background: radial-gradient(circle, #1a3a4a, transparent 70%);
    right: -200px;
    bottom: -100px;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 780px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    animation: heroFadeUp 0.8s ease both;
  }
  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 999px;
    font-size: 12.5px;
    font-weight: 500;
    color: rgba(255,255,255,0.75);
    letter-spacing: 0.01em;
    backdrop-filter: blur(8px);
  }
  .hero-badge__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.4; }
  }
  .hero-title {
    font-size: clamp(32px, 5.5vw, {{ section.settings.title_size }}px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #ffffff;
    margin: 0;
  }
  .hero-dim {
    color: rgba(255,255,255,0.38);
  }
  .hero-desc {
    font-size: 14.5px;
    color: rgba(255,255,255,0.55);
    max-width: 520px;
    line-height: 1.7;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .hero-desc strong {
    color: rgba(255,255,255,0.85);
    font-weight: 600;
  }
  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 26px;
    background: #ffffff;
    color: #0d0d0d;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: -0.01em;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.08);
  }
  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(255,255,255,0.12);
  }
  .hero-cta__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  .hero-social {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero-avatars {
    display: flex;
  }
  .hero-avatar {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 2px solid {{ section.settings.bg_color }};
    margin-left: -10px;
  }
  .hero-avatars .hero-avatar:first-child {
    margin-left: 0;
  }
  .hero-social__info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1px;
  }
  .hero-stars {
    display: flex;
    gap: 1px;
    line-height: 1;
  }
  .hero-social__count {
    font-size: 12px;
    font-weight: 600;
    color: rgba(255,255,255,0.65);
    letter-spacing: -0.01em;
  }
  @media (max-width: 640px) {
    .hero-title { font-size: 30px; }
  }
</style>

{% schema %}
{
  "name": "Hero Dark",
  "tag": "section",
  "class": "section-hero-dark",
  "settings": [
    { "type": "header", "content": "🎨 Couleurs & Style" },
    { "type": "color", "id": "bg_color", "label": "Couleur de fond", "default": "#0d0d0d" },
    { "type": "color", "id": "accent_color", "label": "Couleur d'accent (dot, CTA)", "default": "#00B67A" },
    { "type": "color", "id": "star_color", "label": "Couleur des étoiles", "default": "#00B67A" },
    { "type": "header", "content": "📐 Dimensions" },
    { "type": "range", "id": "min_height", "label": "Hauteur minimum (px)", "min": 300, "max": 900, "step": 10, "default": 520 },
    { "type": "range", "id": "padding_top", "label": "Padding haut (px)", "min": 0, "max": 150, "step": 5, "default": 80 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bas (px)", "min": 0, "max": 150, "step": 5, "default": 80 },
    { "type": "header", "content": "🏷️ Badge" },
    { "type": "text", "id": "badge_text", "label": "Texte du badge", "default": "8lab Ecosystem · The Infinite" },
    { "type": "header", "content": "✏️ Titre" },
    { "type": "range", "id": "title_size", "label": "Taille max du titre (px)", "min": 32, "max": 100, "step": 2, "default": 62 },
    { "type": "text", "id": "title_start", "label": "Début du titre (blanc)", "default": "Le seul écosystème" },
    { "type": "text", "id": "title_highlight_1", "label": "1er mot atténué (gris)", "default": "pour créer" },
    { "type": "text", "id": "title_middle", "label": "Milieu du titre (blanc)", "default": "et scaler" },
    { "type": "checkbox", "id": "title_break", "label": "Saut de ligne après le milieu", "default": true },
    { "type": "text", "id": "title_highlight_2", "label": "2ème mot atténué (gris)", "default": "son" },
    { "type": "text", "id": "title_end", "label": "Fin du titre (blanc)", "default": "empire e-commerce" },
    { "type": "header", "content": "📝 Description" },
    { "type": "text", "id": "description_bold", "label": "Texte en gras", "default": "Nous vous offrons un plan étape par étape," },
    { "type": "textarea", "id": "description", "label": "Suite de la description", "default": " le réseau et les outils pour créer une marque e-commerce pérenne." },
    { "type": "header", "content": "🔘 Bouton CTA" },
    { "type": "text", "id": "cta_text", "label": "Texte du bouton", "default": "Rejoindre au prochain LIVE" },
    { "type": "url", "id": "cta_url", "label": "Lien du bouton" },
    { "type": "checkbox", "id": "show_cta_dot", "label": "Afficher le point animé sur le bouton", "default": true },
    { "type": "header", "content": "👥 Preuve sociale" },
    { "type": "checkbox", "id": "show_social_proof", "label": "Afficher la preuve sociale", "default": true },
    { "type": "text", "id": "social_count", "label": "Texte du compteur", "default": "+2086 membres" }
  ],
  "presets": [{ "name": "Hero Dark" }]
}
{% endschema %}