{% comment %}
  Section: Steps Process (3 étapes)
  Inspiré du design "From idea to live site in 1-2 days"
  Entièrement personnalisable via l'éditeur de thème Shopify
{% endcomment %}

{{ 'steps-process.css' | asset_url | stylesheet_tag }}

<section class="steps-process" id="steps-process-{{ section.id }}">
  <style>
    #steps-process-{{ section.id }} {
      --accent-color: {{ section.settings.accent_color }};
      --badge-bg: {{ section.settings.badge_bg_color }};
      --badge-text: {{ section.settings.badge_text_color }};
      --heading-color: {{ section.settings.heading_color }};
      --body-color: {{ section.settings.body_color }};
      --card-bg: {{ section.settings.card_bg_color }};
      --section-bg: {{ section.settings.section_bg_color }};
    }
  </style>

  <div class="steps-process__wrapper">

    {%- comment %} ── Header ── {%- endcomment %}
    <div class="steps-process__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="steps-process__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="steps-process__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <p class="steps-process__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment %} ── Cards ── {%- endcomment %}
    <div class="steps-process__grid">
      {%- for block in section.blocks -%}
        <div class="steps-process__card" {{ block.shopify_attributes }}>

          {%- comment %} Step badge {%- endcomment %}
          <div class="steps-process__badge">
            <span>{{ block.settings.step_label | default: 'STEP 0' | append: forloop.index }}</span>
          </div>

          {%- comment %} Text content {%- endcomment %}
          <div class="steps-process__card-body">
            {%- if block.settings.card_title != blank -%}
              <h3 class="steps-process__card-title">{{ block.settings.card_title }}</h3>
            {%- endif -%}
            {%- if block.settings.card_description != blank -%}
              <p class="steps-process__card-description">{{ block.settings.card_description }}</p>
            {%- endif -%}
          </div>

          {%- comment %} Image / media area {%- endcomment %}
          <div class="steps-process__card-media">
            {%- if block.settings.card_image != blank -%}
              <div class="steps-process__card-image-wrap">
                {{
                  block.settings.card_image
                  | image_url: width: 600
                  | image_tag:
                    loading: 'lazy',
                    alt: block.settings.card_title,
                    class: 'steps-process__card-image'
                }}
              </div>
            {%- else -%}
              {%- comment %} Placeholder when no image is set {%- endcomment %}
              <div class="steps-process__card-placeholder">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 200" width="300" height="200" aria-hidden="true">
                  <rect width="300" height="200" fill="#e8e8e8" rx="8"/>
                  <rect x="20" y="20" width="260" height="30" rx="4" fill="#d0d0d0"/>
                  <rect x="20" y="65" width="180" height="16" rx="4" fill="#d0d0d0"/>
                  <rect x="20" y="90" width="140" height="16" rx="4" fill="#d0d0d0"/>
                  <rect x="20" y="125" width="260" height="55" rx="6" fill="#c8c8c8"/>
                </svg>
              </div>
            {%- endif -%}

            {%- comment %} Floating badge / tag on the card image {%- endcomment %}
            {%- if block.settings.floating_label != blank -%}
              <div class="steps-process__floating-tag">
                {%- if block.settings.floating_icon != blank -%}
                  <span class="steps-process__floating-icon">{{ block.settings.floating_icon }}</span>
                {%- endif -%}
                {{ block.settings.floating_label }}
              </div>
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}
    </div>

    {%- comment %} ── Optional CTA ── {%- endcomment %}
    {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
      <div class="steps-process__cta">
        <a href="{{ section.settings.cta_url }}" class="steps-process__cta-btn">
          {{ section.settings.cta_label }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
/* ─────────────────────────────────────────
   STEPS PROCESS SECTION — Styles intégrés
   ───────────────────────────────────────── */

#steps-process-{{ section.id }} {
  background-color: var(--section-bg, #f5f5f3);
  padding: {{ section.settings.section_padding_top }}px 20px {{ section.settings.section_padding_bottom }}px;
  font-family: inherit;
}

/* Wrapper */
#steps-process-{{ section.id }} .steps-process__wrapper {
  max-width: 1200px;
  margin: 0 auto;
}

/* ── Header ── */
#steps-process-{{ section.id }} .steps-process__header {
  text-align: center;
  max-width: 720px;
  margin: 0 auto 60px;
}

#steps-process-{{ section.id }} .steps-process__eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent-color, #3b82f6);
  margin: 0 0 16px;
}

#steps-process-{{ section.id }} .steps-process__heading {
  font-size: clamp(28px, 5vw, 52px);
  font-weight: 700;
  line-height: 1.15;
  color: var(--heading-color, #111);
  margin: 0 0 20px;
}

#steps-process-{{ section.id }} .steps-process__subheading {
  font-size: 16px;
  line-height: 1.7;
  color: var(--body-color, #555);
  margin: 0;
}

/* ── Grid ── */
#steps-process-{{ section.id }} .steps-process__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
  align-items: start;
}

/* ── Card ── */
#steps-process-{{ section.id }} .steps-process__card {
  background: var(--card-bg, #ffffff);
  border-radius: 16px;
  padding: 28px 24px 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  position: relative;
  overflow: hidden;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

#steps-process-{{ section.id }} .steps-process__card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 32px rgba(0,0,0,0.1);
}

/* Step badge */
#steps-process-{{ section.id }} .steps-process__badge {
  display: inline-flex;
  align-self: flex-start;
}

#steps-process-{{ section.id }} .steps-process__badge span {
  background: var(--badge-bg, #2563eb);
  color: var(--badge-text, #ffffff);
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 5px 12px;
  border-radius: 6px;
}

/* Card body */
#steps-process-{{ section.id }} .steps-process__card-title {
  font-size: 22px;
  font-weight: 700;
  color: var(--heading-color, #111);
  margin: 0;
  line-height: 1.3;
}

#steps-process-{{ section.id }} .steps-process__card-description {
  font-size: 14px;
  line-height: 1.65;
  color: var(--body-color, #555);
  margin: 0;
}

/* Card media */
#steps-process-{{ section.id }} .steps-process__card-media {
  position: relative;
  border-radius: 10px;
  overflow: hidden;
  margin-top: 8px;
}

#steps-process-{{ section.id }} .steps-process__card-image,
#steps-process-{{ section.id }} .steps-process__card-placeholder svg {
  width: 100%;
  height: auto;
  display: block;
  border-radius: 10px;
}

#steps-process-{{ section.id }} .steps-process__card-placeholder {
  line-height: 0;
}

/* Floating tag on card image */
#steps-process-{{ section.id }} .steps-process__floating-tag {
  position: absolute;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  background: #111;
  color: #fff;
  font-size: 13px;
  font-weight: 600;
  padding: 8px 18px;
  border-radius: 100px;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 6px;
  box-shadow: 0 4px 14px rgba(0,0,0,0.25);
}

#steps-process-{{ section.id }} .steps-process__floating-icon {
  font-size: 15px;
}

/* ── CTA ── */
#steps-process-{{ section.id }} .steps-process__cta {
  text-align: center;
  margin-top: 48px;
}

#steps-process-{{ section.id }} .steps-process__cta-btn {
  display: inline-block;
  background: var(--accent-color, #2563eb);
  color: #fff;
  font-size: 15px;
  font-weight: 600;
  padding: 14px 36px;
  border-radius: 8px;
  text-decoration: none;
  transition: opacity 0.2s ease;
}

#steps-process-{{ section.id }} .steps-process__cta-btn:hover {
  opacity: 0.85;
}

/* ── Responsive ── */
@media (max-width: 768px) {
  #steps-process-{{ section.id }} .steps-process__grid {
    grid-template-columns: 1fr;
  }
  #steps-process-{{ section.id }} .steps-process__heading {
    font-size: 28px;
  }
}
</style>

{% schema %}
{
  "name": "Processus en étapes",
  "tag": "section",
  "class": "steps-process-section",
  "settings": [
    {
      "type": "header",
      "content": "Texte de l'en-tête"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Texte au-dessus du titre (eyebrow)",
      "default": "RAPIDITÉ & SIMPLICITÉ"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Titre principal",
      "default": "De l'idée à la boutique en 1-2 jours"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Sous-titre / description",
      "default": "Arrêtez de perdre du temps sur le design. Notre processus en 3 étapes transforme votre vision en une boutique en ligne de qualité, plus vite que vous ne le pensez."
    },
    {
      "type": "header",
      "content": "Bouton CTA (optionnel)"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texte du bouton"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Lien du bouton"
    },
    {
      "type": "header",
      "content": "Espacement"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Espacement haut",
      "default": 80
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Espacement bas",
      "default": 80
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Fond de la section",
      "default": "#f5f5f3"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Fond des cartes",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Couleur d'accentuation (lien, CTA…)",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Fond des badges STEP",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Texte des badges STEP",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur des titres",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Couleur du texte courant",
      "default": "#555555"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Étape",
      "settings": [
        {
          "type": "text",
          "id": "step_label",
          "label": "Numéro d'étape",
          "default": "STEP 01"
        },
        {
          "type": "text",
          "id": "card_title",
          "label": "Titre de l'étape",
          "default": "Choisissez un template"
        },
        {
          "type": "textarea",
          "id": "card_description",
          "label": "Description de l'étape",
          "default": "Parcourez notre collection de templates premium pour trouver le design parfait pour votre boutique."
        },
        {
          "type": "image_picker",
          "id": "card_image",
          "label": "Image / capture d'écran"
        },
        {
          "type": "text",
          "id": "floating_label",
          "label": "Texte du badge flottant (optionnel)",
          "default": "✦  Webflow · Figma · Framer"
        },
        {
          "type": "text",
          "id": "floating_icon",
          "label": "Emoji / icône du badge flottant"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Processus en étapes",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_label": "STEP 01",
            "card_title": "Choisissez un template",
            "card_description": "Parcourez notre collection de templates premium pour trouver le design parfait pour votre projet.",
            "floating_label": "Webflow · Figma · Framer"
          }
        },
        {
          "type": "step",
          "settings": {
            "step_label": "STEP 02",
            "card_title": "Personnalisez-le",
            "card_description": "Modifiez facilement les contenus, couleurs et typographies en quelques minutes pour refléter votre marque.",
            "floating_label": "Contenu · Polices · Layout"
          }
        },
        {
          "type": "step",
          "settings": {
            "step_label": "STEP 03",
            "card_title": "Publiez instantanément",
            "card_description": "Mettez votre boutique en ligne en un clic. Aucun code, aucun développeur, aucun stress.",
            "floating_label": "🚀  Publier"
          }
        }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}