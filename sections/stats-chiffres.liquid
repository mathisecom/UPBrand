{% comment %}
  Section: Chiffres clés / Stats
  Design sombre avec 4 métriques en ligne
  Entièrement personnalisable via l'éditeur de thème Shopify
{% endcomment %}

<section class="stats-section" id="stats-{{ section.id }}">
  <style>
    #stats-{{ section.id }} {
      background-color: {{ section.settings.bg_color }};
      padding: {{ section.settings.padding_top }}px 40px {{ section.settings.padding_bottom }}px;
      position: relative;
      overflow: hidden;
    }

    {%- if section.settings.show_stars %}
    #stats-{{ section.id }}::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image:
        radial-gradient(1px 1px at 10% 20%, rgba(255,255,255,0.5) 0%, transparent 100%),
        radial-gradient(1px 1px at 25% 60%, rgba(255,255,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 40% 10%, rgba(255,255,255,0.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 55% 80%, rgba(255,255,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 70% 35%, rgba(255,255,255,0.5) 0%, transparent 100%),
        radial-gradient(1px 1px at 80% 70%, rgba(255,255,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 90% 15%, rgba(255,255,255,0.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 15% 85%, rgba(255,255,255,0.2) 0%, transparent 100%),
        radial-gradient(1px 1px at 60% 50%, rgba(255,255,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 35% 40%, rgba(255,255,255,0.2) 0%, transparent 100%),
        radial-gradient(1.5px 1.5px at 48% 25%, rgba(255,255,255,0.4) 0%, transparent 100%),
        radial-gradient(1px 1px at 75% 55%, rgba(255,255,255,0.3) 0%, transparent 100%),
        radial-gradient(1px 1px at 5%  50%, rgba(255,255,255,0.2) 0%, transparent 100%),
        radial-gradient(1px 1px at 95% 45%, rgba(255,255,255,0.3) 0%, transparent 100%);
      pointer-events: none;
    }
    {%- endif %}

    {%- if section.settings.show_glow %}
    #stats-{{ section.id }}::after {
      content: '';
      position: absolute;
      left: -10%;
      top: -60%;
      width: 40%;
      height: 200%;
      background: radial-gradient(ellipse, {{ section.settings.glow_color }} 0%, transparent 65%);
      pointer-events: none;
      opacity: 0.5;
    }
    {%- endif %}

    #stats-{{ section.id }} .stats-wrap {
      max-width: {{ section.settings.max_width }}px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat({{ section.blocks.size | at_most: 4 }}, 1fr);
      gap: {{ section.settings.gap }}px;
      position: relative;
      z-index: 1;
    }

    #stats-{{ section.id }} .stats-item {
      display: flex;
      flex-direction: column;
      align-items: {{ section.settings.alignment }};
      gap: 10px;
    }

    {%- if section.settings.show_dividers %}
    #stats-{{ section.id }} .stats-item + .stats-item {
      border-left: 1px solid {{ section.settings.divider_color }};
      padding-left: {{ section.settings.gap | divided_by: 2 }}px;
    }
    {%- endif %}

    #stats-{{ section.id }} .stats-number {
      font-size: clamp({{ section.settings.number_size_min }}px, 4vw, {{ section.settings.number_size_max }}px);
      font-weight: 800;
      color: {{ section.settings.number_color }};
      line-height: 1;
      margin: 0;
      letter-spacing: -0.02em;
    }

    #stats-{{ section.id }} .stats-label {
      font-size: clamp(13px, 1.5vw, {{ section.settings.label_size }}px);
      color: {{ section.settings.label_color }};
      line-height: 1.4;
      margin: 0;
      text-align: {{ section.settings.alignment | replace: 'flex-start', 'left' | replace: 'flex-end', 'right' | replace: 'center', 'center' }};
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      #stats-{{ section.id }} .stats-wrap {
        grid-template-columns: repeat(2, 1fr);
        gap: 32px 20px;
      }
      {%- if section.settings.show_dividers %}
      #stats-{{ section.id }} .stats-item + .stats-item {
        border-left: none;
        padding-left: 0;
      }
      #stats-{{ section.id }} .stats-item:nth-child(even) {
        border-left: 1px solid {{ section.settings.divider_color }};
        padding-left: 20px;
      }
      {%- endif %}
    }

    @media (max-width: 480px) {
      #stats-{{ section.id }} {
        padding-left: 20px;
        padding-right: 20px;
      }
    }
  </style>

  <div class="stats-wrap">
    {%- for block in section.blocks -%}
      <div class="stats-item" {{ block.shopify_attributes }}>
        {%- if block.settings.number != blank -%}
          <p class="stats-number">{{ block.settings.number }}</p>
        {%- endif -%}
        {%- if block.settings.label != blank -%}
          <p class="stats-label">{{ block.settings.label }}</p>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

</section>

{% schema %}
{
  "name": "Chiffres clés / Stats",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Mise en page"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 600,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "label": "Largeur maximale",
      "default": 1100
    },
    {
      "type": "range",
      "id": "gap",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Espacement entre les stats",
      "default": 40
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignement du contenu",
      "options": [
        { "value": "flex-start", "label": "Gauche" },
        { "value": "center",     "label": "Centre" },
        { "value": "flex-end",   "label": "Droite" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Espacement section"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Espacement haut",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Espacement bas",
      "default": 60
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Couleur de fond",
      "default": "#0d0d1a"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "Couleur des chiffres",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Couleur des labels",
      "default": "#aaaaaa"
    },
    {
      "type": "header",
      "content": "Typographie"
    },
    {
      "type": "range",
      "id": "number_size_min",
      "min": 24,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Taille chiffres (mobile)",
      "default": 36
    },
    {
      "type": "range",
      "id": "number_size_max",
      "min": 40,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Taille chiffres (desktop)",
      "default": 60
    },
    {
      "type": "range",
      "id": "label_size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Taille labels (desktop)",
      "default": 16
    },
    {
      "type": "header",
      "content": "Séparateurs"
    },
    {
      "type": "checkbox",
      "id": "show_dividers",
      "label": "Afficher les séparateurs verticaux",
      "default": false
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Couleur des séparateurs",
      "default": "#2a2a3a"
    },
    {
      "type": "header",
      "content": "Effets décoratifs"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Afficher les étoiles / particules",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_glow",
      "label": "Afficher le halo lumineux",
      "default": true
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Couleur du halo",
      "default": "#4a3080"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistique",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Chiffre / valeur",
          "default": "+500"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Description",
          "default": "Marques créées depuis 2023"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Chiffres clés / Stats",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "number": "+500",
            "label": "Marques créées depuis 2023"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "+16M€",
            "label": "CA généré par nos membres"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "99,7%",
            "label": "Satisfaction de nos membres"
          }
        },
        {
          "type": "stat",
          "settings": {
            "number": "90 jours",
            "label": "Accompagnement garanti"
          }
        }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}