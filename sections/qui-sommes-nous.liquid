<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<section class="qsn-section">
  <div class="qsn-inner">

    {% if section.settings.badge_text != blank %}
    <div class="qsn-badge">
      <span class="qsn-dot"></span>
      {{ section.settings.badge_text }}
    </div>
    {% endif %}

    <h2 class="qsn-heading">{{ section.settings.heading }}</h2>

    {% if section.settings.subheading != blank %}
    <p class="qsn-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="qsn-cards">
      {% for block in section.blocks %}
        {% if block.type == 'member' %}
        <div class="qsn-card" {{ block.shopify_attributes }}>

          <div class="qsn-card-left">
            {% if block.settings.photo != blank %}
              <img
                src="{{ block.settings.photo | img_url: '400x400', crop: 'center' }}"
                class="qsn-photo"
                alt="{{ block.settings.name }}"
                loading="lazy"
              >
            {% else %}
              <div class="qsn-photo qsn-photo--fallback">
                <span>{{ block.settings.name | slice: 0 }}</span>
              </div>
            {% endif %}

            {% if block.settings.badge_logo != blank %}
            <div class="qsn-logo-badge">
              <img src="{{ block.settings.badge_logo | img_url: '80x' }}" alt="badge" class="qsn-badge-img">
            </div>
            {% elsif block.settings.badge_type == 'shopify' %}
            <div class="qsn-logo-badge">
              <svg class="qsn-shopify-icon" viewBox="0 0 50 57" xmlns="http://www.w3.org/2000/svg" fill="none">
                <path d="M43.6 10.8c0-.3-.3-.5-.6-.5-.3 0-5.8-.4-5.8-.4s-3.9-3.8-4.3-4.2c-.4-.4-1.2-.3-1.5-.2-.1 0-.7.2-1.7.5C28.5 4 26.8 2 24.2 2c-.1 0-.2 0-.3 0C23.2.8 22.1.2 21.2.2c-7.4 0-11 9.3-12.1 14-.3.8.1 1.6.9 1.8.3.1 3.4 1.1 3.4 1.1L11.2 24c-1 3.4-1 3.4-.9 3.6L13 55c.1.5.5.8 1 .8h.1l21.4-4.1c.4-.1.7-.4.8-.8L43.8 11.3c0-.2 0-.4-.2-.5zM29.9 7.5c-.7.2-1.5.5-2.4.7v-.6c0-1.6-.2-2.9-.6-3.9 1.5.3 2.5 1.9 3 3.8zm-5.7-3.4c.4 1 .7 2.4.7 4.3v.3c-1.8.5-3.7 1.2-5.6 1.7C20.4 7 22.2 4.3 24.2 4.1zm-3.8-1.9c.3 0 .6.1.9.3-2.4.3-4.9 2.8-6.1 7.4l-3.9 1.2C12.4 6.6 15.5 2.2 20.4 2.2z" fill="#95BF47"/>
                <path d="M43 10.3c-.3 0-5.8-.4-5.8-.4s-3.9-3.8-4.3-4.2c-.2-.2-.4-.2-.6-.2l-3.2 55 21.4-4.1L43.6 11c-.1-.4-.4-.7-.6-.7z" fill="#5E8E3E"/>
                <path d="M26.9 19.6l-2.6 7.8s-2.3-1.2-5.1-1.2c-4.1 0-4.3 2.6-4.3 3.2 0 3.5 9.2 4.9 9.2 13.1 0 6.5-4.1 10.7-9.7 10.7-6.6 0-10-4.2-10-4.2l1.8-5.8s3.5 3 6.4 3c1.9 0 2.7-1.5 2.7-2.6 0-4.5-7.5-4.7-7.5-12.2 0-6.3 4.5-12.4 13.6-12.4 3.5 0 5.5 1 5.5 1z" fill="#fff"/>
              </svg>
              <span>shopify</span>
            </div>
            {% endif %}
          </div>

          <div class="qsn-card-right">
            <div class="qsn-card-top">
              <div class="qsn-name-block">
                <h3 class="qsn-name">{{ block.settings.name }}</h3>
                <p class="qsn-role" style="color: {{ block.settings.role_color }};">{{ block.settings.role }}</p>
              </div>
            </div>

            <p class="qsn-bio">{{ block.settings.bio }}</p>

            {% if block.settings.stat_1_value != blank or block.settings.stat_2_value != blank or block.settings.stat_3_value != blank %}
            <div class="qsn-stats">
              {% if block.settings.stat_1_value != blank %}
              <div class="qsn-stat">
                <span class="qsn-stat-val" style="color:{{ section.settings.accent_color }};">{{ block.settings.stat_1_value }}</span>
                <span class="qsn-stat-lbl">{{ block.settings.stat_1_label }}</span>
              </div>
              {% endif %}
              {% if block.settings.stat_2_value != blank %}
              <div class="qsn-stat">
                <span class="qsn-stat-val" style="color:{{ section.settings.accent_color }};">{{ block.settings.stat_2_value }}</span>
                <span class="qsn-stat-lbl">{{ block.settings.stat_2_label }}</span>
              </div>
              {% endif %}
              {% if block.settings.stat_3_value != blank %}
              <div class="qsn-stat">
                <span class="qsn-stat-val" style="color:{{ section.settings.accent_color }};">{{ block.settings.stat_3_value }}</span>
                <span class="qsn-stat-lbl">{{ block.settings.stat_3_label }}</span>
              </div>
              {% endif %}
            </div>
            {% endif %}

          </div>
        </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

<style>
  .qsn-section {
    background: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 24px {{ section.settings.padding_bottom }}px;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .qsn-inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  /* ── Badge ── */
  .qsn-badge {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 5px 14px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 999px;
    font-size: 12px; font-weight: 500;
    color: rgba(255,255,255,0.65);
    letter-spacing: 0.01em;
  }
  .qsn-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: {{ section.settings.accent_color }};
    box-shadow: 0 0 6px {{ section.settings.accent_color }};
    animation: qsnPulse 2s ease-in-out infinite;
  }
  @keyframes qsnPulse { 0%,100%{opacity:1} 50%{opacity:.35} }

  /* ── Heading ── */
  .qsn-heading {
    font-size: clamp(24px, 4vw, {{ section.settings.heading_size }}px);
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    text-align: center;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0;
  }

  .qsn-subheading {
    font-size: 15px;
    color: rgba(255,255,255,0.45);
    text-align: center;
    max-width: 560px;
    line-height: 1.7;
    margin: 0;
  }

  /* ── Cards grid ── */
  .qsn-cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    margin-top: 8px;
  }

  /* ── Single card ── */
  .qsn-card {
    display: flex;
    align-items: stretch;
    gap: 0;
    background: {{ section.settings.card_bg }};
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.07);
  }

  /* ── Left : photo ── */
  .qsn-card-left {
    position: relative;
    flex: 0 0 {{ section.settings.photo_width }}px;
    min-height: 200px;
  }

  .qsn-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  .qsn-photo--fallback {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #2a2a2a, #1a1a1a);
    display: flex; align-items: center; justify-content: center;
    font-size: 48px; font-weight: 800; color: rgba(255,255,255,0.3);
  }

  /* Logo badge */
  .qsn-logo-badge {
    position: absolute;
    top: 12px; right: 12px;
    background: {{ section.settings.card_bg }};
    border-radius: 8px;
    padding: 5px 9px;
    display: flex; align-items: center; gap: 5px;
    border: 1px solid rgba(255,255,255,0.1);
  }
  .qsn-shopify-icon { width: 18px; height: 20px; }
  .qsn-logo-badge span {
    font-size: 13px; font-weight: 700;
    color: rgba(255,255,255,0.85);
    letter-spacing: -0.3px;
  }
  .qsn-badge-img { height: 20px; width: auto; }

  /* ── Right : content ── */
  .qsn-card-right {
    flex: 1;
    padding: 24px 28px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    justify-content: center;
    border-left: 1px solid rgba(255,255,255,0.07);
  }

  .qsn-card-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
  .qsn-name-block { display: flex; flex-direction: column; gap: 2px; }

  .qsn-name {
    font-size: 18px; font-weight: 800;
    color: {{ section.settings.heading_color }};
    letter-spacing: -0.03em; margin: 0;
    line-height: 1.1;
  }

  .qsn-role {
    font-size: 13px; font-weight: 600;
    margin: 0; letter-spacing: -0.01em;
  }

  .qsn-bio {
    font-size: 14px;
    color: rgba(255,255,255,0.55);
    line-height: 1.75;
    margin: 0;
    letter-spacing: -0.01em;
  }

  /* ── Stats ── */
  .qsn-stats {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    padding-top: 14px;
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .qsn-stat { display: flex; flex-direction: column; gap: 2px; }
  .qsn-stat-val {
    font-size: 20px; font-weight: 800;
    letter-spacing: -0.04em; line-height: 1;
  }
  .qsn-stat-lbl {
    font-size: 11px; font-weight: 500;
    color: rgba(255,255,255,0.4);
    letter-spacing: -0.01em;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .qsn-card { flex-direction: column; }
    .qsn-card-left { flex: 0 0 auto; height: 220px; }
    .qsn-card-right { border-left: none; border-top: 1px solid rgba(255,255,255,0.07); padding: 20px; }
    .qsn-stats { gap: 16px; }
  }
</style>

{% schema %}
{
  "name": "Qui Sommes Nous",
  "tag": "section",
  "class": "section-qui-sommes-nous",
  "settings": [
    { "type": "header", "content": "🎨 Style global" },
    { "type": "color", "id": "bg_color", "label": "Couleur de fond", "default": "#0d0d0d" },
    { "type": "color", "id": "card_bg", "label": "Fond des cartes", "default": "#1a1a1a" },
    { "type": "color", "id": "heading_color", "label": "Couleur titres", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Couleur accent (stats)", "default": "#f59e0b" },
    { "type": "range", "id": "card_radius", "label": "Arrondi des cartes", "min": 0, "max": 32, "step": 2, "default": 16 },
    { "type": "range", "id": "photo_width", "label": "Largeur photo (px)", "min": 160, "max": 340, "step": 10, "default": 220 },

    { "type": "header", "content": "📐 Espacement" },
    { "type": "range", "id": "padding_top", "label": "Padding haut (px)", "min": 0, "max": 150, "step": 5, "default": 70 },
    { "type": "range", "id": "padding_bottom", "label": "Padding bas (px)", "min": 0, "max": 150, "step": 5, "default": 70 },
    { "type": "range", "id": "max_width", "label": "Largeur max (px)", "min": 600, "max": 1400, "step": 20, "default": 900 },

    { "type": "header", "content": "🏷️ En-tête de section" },
    { "type": "text", "id": "badge_text", "label": "Texte badge", "default": "Notre équipe" },
    { "type": "text", "id": "heading", "label": "Titre principal", "default": "Qui Sommes-Nous ?" },
    { "type": "range", "id": "heading_size", "label": "Taille titre (px)", "min": 24, "max": 72, "step": 2, "default": 42 },
    { "type": "textarea", "id": "subheading", "label": "Sous-titre (optionnel)", "default": "Une équipe passionnée, dédiée à faire croître votre e-commerce." }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Membre de l'équipe",
      "settings": [
        { "type": "image_picker", "id": "photo", "label": "Photo du membre" },
        { "type": "text", "id": "name", "label": "Nom complet", "default": "Mehdi Elshamy" },
        { "type": "text", "id": "role", "label": "Titre / Rôle", "default": "Expert en Création de Site" },
        { "type": "color", "id": "role_color", "label": "Couleur du rôle", "default": "#f59e0b" },
        { "type": "textarea", "id": "bio", "label": "Biographie", "default": "Expert en création de sites web et branding, Mehdi vous dévoilera étape par étape sa méthodologie pour concevoir des boutiques en ligne performantes. Ayant créé des sites qui ont généré plusieurs dizaines de millions de dollars de ventes, son approche stratégique garantit des plateformes qui convertissent efficacement." },
        { "type": "header", "content": "🏷️ Badge logo" },
        { "type": "select", "id": "badge_type", "label": "Badge intégré", "options": [
            { "value": "none", "label": "Aucun" },
            { "value": "shopify", "label": "Shopify" }
          ], "default": "shopify"
        },
        { "type": "image_picker", "id": "badge_logo", "label": "Logo personnalisé (remplace le badge intégré)" },
        { "type": "header", "content": "📊 Statistiques (optionnel)" },
        { "type": "text", "id": "stat_1_value", "label": "Stat 1 — Valeur", "default": "$40M+" },
        { "type": "text", "id": "stat_1_label", "label": "Stat 1 — Label", "default": "de CA générés" },
        { "type": "text", "id": "stat_2_value", "label": "Stat 2 — Valeur", "default": "200+" },
        { "type": "text", "id": "stat_2_label", "label": "Stat 2 — Label", "default": "boutiques créées" },
        { "type": "text", "id": "stat_3_value", "label": "Stat 3 — Valeur", "default": "8 ans" },
        { "type": "text", "id": "stat_3_label", "label": "Stat 3 — Label", "default": "d'expérience" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Qui Sommes Nous",
      "blocks": [
        { "type": "member" }
      ]
    }
  ]
}
{% endschema %}
